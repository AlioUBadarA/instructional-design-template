# Copier ce fichier en .env et remplir les valeurs

# PostgreSQL - fourni par Render (copier depuis le dashboard Render)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT - chaine aleatoire longue (min 32 caracteres)
JWT_SECRET=remplacer_par_une_chaine_secrete_longue_et_aleatoire

# URL du frontend (optionnel, laisse * pour autoriser tout)
FRONTEND_URL=https://votre-frontend.onrender.com

# Environnement
NODE_ENV=production
